# ============================================================
# Hermes Autonomous Trading System - Environment Configuration
# Copy to .env and fill in your values
# chmod 600 .env
# ============================================================

# --- Mode ---
TRADER_MODE=PAPER_AUTONOMOUS
ENABLE_LIVE_TRADING=false
LIVE_AUTONOMY_MODE=DISABLED
LIVE_CONFIRMATION_PHRASE=DISABLED

# --- Alpaca ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=
ALPACA_MCP_ENABLED=true
ALPACA_TOOLSETS=account,market_data,trading

# --- Account Mandate ---
MAX_EXPERIMENT_CAPITAL_USD=20.00
MAX_ACCOUNT_EQUITY_USD=25.00
MAX_SINGLE_TRADE_LOSS_USD=1.50
ABSOLUTE_SINGLE_TRADE_LOSS_CAP_USD=2.00
MAX_DAILY_LOSS_USD=1.50
MAX_WEEKLY_LOSS_USD=3.00
MAX_MONTHLY_LOSS_USD=6.00
MIN_CASH_RESERVE_USD=2.00

# --- Trade Limits ---
MAX_OPEN_POSITIONS=1
MAX_NEW_TRADES_PER_DAY=1
MAX_NEW_TRADES_PER_WEEK=3
MAX_CONSECUTIVE_LOSSES=3
MAX_EQUITY_ORDER_NOTIONAL_USD=5.00
MAX_POSITION_NOTIONAL_USD=8.00

# --- Assets ---
ALLOWED_UNDERLYINGS=SPY,QQQ,VOO
ALLOW_EQUITIES=true
ALLOW_OPTIONS=true
ALLOW_CRYPTO=false
ALLOW_FOREX=false
ALLOW_FUTURES=false
ALLOW_MARGIN=false

# --- Options ---
ALLOW_LONG_CALLS=true
ALLOW_LONG_PUTS=true
ALLOW_DEBIT_SPREADS_PAPER=true
ALLOW_DEBIT_SPREADS_LIVE=false
ALLOW_CREDIT_SPREADS=false
ALLOW_NAKED_OPTIONS=false
ALLOW_SHORT_OPTIONS=false
ALLOW_0DTE=false
MIN_DAYS_TO_EXPIRATION=3
MAX_DAYS_TO_EXPIRATION=21
EXPIRATION_DANGER_WINDOW_DAYS=2
MAX_OPTION_PREMIUM_USD=2.00
MAX_OPTION_SPREAD_WIDTH_USD=1.00
MAX_CONTRACTS=1
MIN_OPEN_INTEREST=100
MIN_VOLUME=50
MAX_BID_ASK_SPREAD_PCT=15

# --- Execution ---
REQUIRE_MARKET_OPEN=true
USE_LIMIT_ORDERS_FOR_OPTIONS=true
OPTION_ORDER_TIMEOUT_SECONDS=300
EQUITY_ORDER_TIMEOUT_SECONDS=600
ALLOW_ORDER_CHASING=false
MAX_ORDER_RESUBMISSIONS=1

# --- Research Tools ---
VIBE_TRADING_ENABLED=true
VIBE_TRADING_PATH=/opt/Vibe-Trading
VIBE_TRADING_MCP_ENABLED=true
TRADINGAGENTS_ENABLED=true
TRADINGAGENTS_PATH=/opt/TradingAgents

# --- Telegram Reports ---
TELEGRAM_REPORTS=true
TELEGRAM_MIN_REPORT_LEVEL=INFO
REPORT_EVERY_CYCLE=true
REPORT_ERRORS_IMMEDIATELY=true

# --- Files ---
PROJECT_ROOT=/opt/hermes-trader
KILL_SWITCH_PATH=/opt/hermes-trader/KILL_SWITCH
LOG_DIR=/opt/hermes-trader/logs
DATA_DIR=/opt/hermes-trader/data

# --- Security ---
REDACT_SECRETS=true
LOCAL_ONLY_API=true
BIND_HOST=127.0.0.1
API_AUTH_REQUIRED=true